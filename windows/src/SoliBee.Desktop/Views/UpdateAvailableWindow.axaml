<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SoliBee.Desktop.Views.UpdateAvailableWindow"
        Title="Update Available"
        Width="340" Height="190"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="White"
        ShowInTaskbar="False">

    <Grid RowDefinitions="*, Auto" Margin="24">
        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
            <TextBlock Text="Update Available"
                       FontSize="18" FontWeight="Bold"
                       Foreground="#1A1A1A"
                       HorizontalAlignment="Center" />
            <TextBlock x:Name="MessageText"
                       FontSize="12" Foreground="#555555"
                       TextWrapping="Wrap" TextAlignment="Center"
                       Width="280"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal" Spacing="8"
                    HorizontalAlignment="Center"
                    Margin="0,16,0,0">
            <Button Content="Don't Ask Again"
                    Click="DeclineUpdate_Click"
                    Classes="light-secondary" />
            <Button Content="View Release"
                    Click="ViewRelease_Click"
                    Classes="light-primary" />
        </StackPanel>
    </Grid>
</Window>
