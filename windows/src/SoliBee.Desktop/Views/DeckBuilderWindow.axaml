<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SoliBee.Desktop.Views"
        x:Class="SoliBee.Desktop.Views.DeckBuilderWindow"
        Title="Deck Builder" Width="900" Height="850"
        WindowStartupLocation="CenterOwner"
        Background="White" CornerRadius="16"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1">
        
    <Window.Styles>
        <Style Selector="Button.honeycomb-action">
            <Setter Property="Background" Value="#A0C0FF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="Button.honeycomb-cancel">
            <Setter Property="Background" Value="#E0E0E0" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#F0F0F0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10,5" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto, Auto, *, Auto" Margin="30">
        
        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Deck Builder" FontSize="32" FontWeight="Black" HorizontalAlignment="Center" Margin="0,10,0,20" Foreground="#1A1A1A"/>
        
        <!-- Deck Name -->
        <TextBox Grid.Row="1" x:Name="DeckNameTextBox" Width="400" MaxLength="20" Watermark="Deck Name (Max 20 chars)" FontSize="18" Padding="10" CornerRadius="8" BorderBrush="#80A0FF" BorderThickness="3" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Your Deck Area -->
        <Border Grid.Row="2" Background="#EDF2F7" CornerRadius="12" Padding="20" Margin="0,0,0,20" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock x:Name="YourDeckTitle" Text="Your Deck (0/5) - Tap to Remove" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15" Foreground="#1A1A1A"/>
                <StackPanel x:Name="DeckSlotsPanel" Orientation="Horizontal" Spacing="15" HorizontalAlignment="Center">
                    <!-- 5 card views populated in code behind -->
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Card Bank Area -->
        <Grid Grid.Row="2" RowDefinitions="Auto, *" Margin="0,220,0,0">
            <StackPanel Grid.Row="0" Spacing="10" Margin="0,0,0,15">
                <TextBlock Text="Card Bank - Tap to Add" FontSize="16" FontWeight="Bold" Foreground="#1A1A1A"/>
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <ComboBox x:Name="StarsFilter" Width="120" SelectionChanged="FilterCombo_SelectionChanged">
                        <ComboBoxItem Content="All Stars" />
                        <ComboBoxItem Content="1 Star" />
                        <ComboBoxItem Content="2 Stars" />
                        <ComboBoxItem Content="3 Stars" />
                        <ComboBoxItem Content="4 Stars" />
                        <ComboBoxItem Content="5 Stars" />
                    </ComboBox>
                    <ComboBox x:Name="SuitsFilter" Width="120" SelectionChanged="FilterCombo_SelectionChanged">
                        <ComboBoxItem Content="All Suits" />
                        <ComboBoxItem Content="Spades" />
                        <ComboBoxItem Content="Hearts" />
                        <ComboBoxItem Content="Diamonds" />
                        <ComboBoxItem Content="Clubs" />
                    </ComboBox>
                    <ToggleButton x:Name="FavoritesFilter" Content="★ Favorites" CornerRadius="8" Background="#F0F0F0" Padding="10,5" Checked="FilterToggle_CheckedChanged" Unchecked="FilterToggle_CheckedChanged"/>
                </StackPanel>
            </StackPanel>
            
            <ScrollViewer Grid.Row="1">
                <WrapPanel x:Name="BankPanel" ItemWidth="130" ItemHeight="170" Margin="0,10,0,0" />
            </ScrollViewer>
        </Grid>

        <!-- Buttons -->
        <Grid Grid.Row="3" ColumnDefinitions="*, Auto" Margin="0,20,0,0">
            <TextBlock x:Name="ErrorText" Grid.Column="0" Foreground="#FF5555" FontSize="14" TextWrapping="Wrap" VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="20" HorizontalAlignment="Center">
                <Button Content="Cancel" Classes="honeycomb-cancel" Click="Cancel_Click" />
                <Button x:Name="SaveButton" Content="Save Deck" Classes="honeycomb-action" Click="Save_Click" />
            </StackPanel>
        </Grid>
        
    </Grid>
</Window>
