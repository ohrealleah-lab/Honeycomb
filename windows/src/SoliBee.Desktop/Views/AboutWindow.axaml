<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SoliBee.Desktop.Views.AboutWindow"
        Title="About Honeycomb"
        Width="340" Height="290"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="White"
        ShowInTaskbar="False">

    <Grid RowDefinitions="*, Auto">
        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="6" Margin="32,24,32,12">

            <TextBlock Text="Honeycomb"
                       FontSize="32" FontWeight="Black"
                       Foreground="#1A1A1A"
                       HorizontalAlignment="Center"
                       FontFamily="Segoe UI" />

            <TextBlock Text="Card Suite"
                       FontSize="13" FontWeight="SemiBold"
                       Foreground="#707070"
                       HorizontalAlignment="Center"
                       LetterSpacing="2" />

            <Border Height="1" Background="#DDDDDD" Margin="0,6,0,6" />

            <TextBlock x:Name="VersionText"
                       FontSize="12" Foreground="#555555"
                       HorizontalAlignment="Center" />

            <TextBlock Text="© 2026 Leahbee. All rights reserved."
                       FontSize="11" Foreground="#808080"
                       HorizontalAlignment="Center" />

            <TextBlock Text="For Rhinestone."
                       FontSize="11" Foreground="#707070" FontStyle="Italic"
                       HorizontalAlignment="Center" Margin="0,4,0,0" />

            <Border Height="1" Background="#DDDDDD" Margin="0,6,0,6" />

            <Button x:Name="CheckForUpdatesButton"
                    Content="Check for Updates…"
                    Click="CheckForUpdates_Click"
                    Classes="light-secondary"
                    FontSize="11"
                    HorizontalAlignment="Center"
                    HorizontalContentAlignment="Center" />

            <TextBlock x:Name="UpdateStatusText"
                       FontSize="11" Foreground="#707070"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Width="260"
                       IsVisible="False" />

            <Button x:Name="InstallUpdateButton"
                    Content="Install &amp; Restart"
                    Click="InstallUpdate_Click"
                    Classes="light-primary"
                    FontSize="11"
                    IsVisible="False" />
        </StackPanel>

        <Button Grid.Row="1"
                Content="Close"
                Click="Close_Click"
                HorizontalAlignment="Right"
                Margin="0,0,20,16"
                Width="80"
                HorizontalContentAlignment="Center"
                Classes="light-secondary" />
    </Grid>
</Window>
