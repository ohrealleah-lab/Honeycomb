<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SoliBee.Desktop.Views.CardView"
             PointerPressed="CardView_PointerPressed"
             PointerMoved="CardView_PointerMoved"
             PointerReleased="CardView_PointerReleased">

    <Grid x:Name="CardRoot" Width="128" Height="181">
        <!-- Card Face (Face Up) -->
        <Border x:Name="CardFace" BorderBrush="#D9000000" BorderThickness="0.75" Background="White" CornerRadius="10" Padding="4" BoxShadow="0 1.5 1.5 0 #26000000">
            <Grid>
                <!-- Top-Left Value & Suit Display (Horizontal) -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Spacing="2" Margin="4,2,0,0">
                    <TextBlock x:Name="RankText" FontSize="17" FontFamily="Courier New, Consolas, monospace" FontWeight="Bold" Foreground="Black" />
                    <TextBlock x:Name="MiniSuitText" FontSize="14" Foreground="Black" VerticalAlignment="Center" />
                </StackPanel>

                <!-- Center Content: Grid for numbered cards OR single large letter for face cards -->
                <Grid x:Name="CenterGrid" Width="86" Height="138" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!-- Standard canvas for numbered cards (2-10) -->
                    <Canvas x:Name="SuitCanvas" Width="86" Height="138" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="False" />

                    <!-- Large stylized letter for Ace -->
                    <TextBlock x:Name="LargeAceText" FontSize="61" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" IsVisible="False" />

                    <!-- Image for Face Cards J, Q, K -->
                    <Image x:Name="FaceCardImage" Width="70" Height="108" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="False" />
                </Grid>

                <!-- Bottom-Right Value & Suit Display (Horizontal, Rotated 180 degrees) -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Spacing="2" Margin="0,0,4,2" RenderTransformOrigin="50%,50%">
                    <StackPanel.RenderTransform>
                        <RotateTransform Angle="180" />
                    </StackPanel.RenderTransform>
                    <TextBlock x:Name="RankTextBottom" FontSize="17" FontFamily="Courier New, Consolas, monospace" FontWeight="Bold" Foreground="Black" />
                    <TextBlock x:Name="MiniSuitTextBottom" FontSize="14" Foreground="Black" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Card Back (Face Down) -->
        <Border x:Name="CardBack" BorderBrush="#D9000000" BorderThickness="0.75" CornerRadius="10" IsVisible="False" Padding="0" Background="White" BoxShadow="0 1.5 1.5 0 #26000000" ClipToBounds="True">
            <Grid x:Name="CardBackGrid" Width="128" Height="181" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image x:Name="CardBackImage" Stretch="Fill" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
