<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SoliBee.Desktop.Views.FlashToast"
             IsVisible="False" IsHitTestVisible="False" ZIndex="5"
             HorizontalAlignment="Center" VerticalAlignment="Center"
             Opacity="0">
    <UserControl.Transitions>
        <Transitions>
            <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseOut"/>
        </Transitions>
    </UserControl.Transitions>
    <!-- Generic transient "flash a short message" banner — same banner-glow dark-card,
         gold-headline look as the other overlay banners (e.g. Video Poker's
         "Not today, partner!" toast), but headline-only and self-dismissing rather than
         needing a dismiss button, since the message is purely informational. -->
    <Border Classes="banner-glow" Background="#BF000000" CornerRadius="24" Padding="48,36" MaxWidth="920">
        <TextBlock x:Name="MessageText" FontSize="72" FontWeight="Black" Foreground="#FFD600"
                   HorizontalAlignment="Center" FontFamily="Segoe UI" TextAlignment="Center" TextWrapping="Wrap"/>
    </Border>
</UserControl>
