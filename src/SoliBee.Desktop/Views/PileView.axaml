<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SoliBee.Desktop.Views.PileView"
             PointerPressed="PileView_PointerPressed"
             ClipToBounds="False">

    <Grid x:Name="PileGrid" Width="128" HorizontalAlignment="Left" ClipToBounds="False">
        <!-- Programmatic vector empty pile slot outline -->
        <Rectangle x:Name="EmptyOutline" Width="128" Height="181" Stroke="White" StrokeThickness="1.5" RadiusX="10" RadiusY="10" Opacity="0.35" Fill="#15FFFFFF" HorizontalAlignment="Left" VerticalAlignment="Top" />

        <!-- Symbol for empty foundations ("A") or Stock recycle ("↺") -->
        <TextBlock x:Name="EmptySymbolText" Width="128" FontSize="51" Foreground="White" Opacity="0.2" HorizontalAlignment="Left" VerticalAlignment="Center" TextAlignment="Center" Margin="0,0,0,10" IsHitTestVisible="False" />

        <!-- Programmatic container for overlaying card stack views -->
        <Canvas x:Name="CardsCanvas" Width="128" Height="181" HorizontalAlignment="Left" VerticalAlignment="Top" ClipToBounds="False" />
    </Grid>
</UserControl>
