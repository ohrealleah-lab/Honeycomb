<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SoliBee.Desktop.Views.WinAnimationView">

    <Grid>
        <!-- Bouncing card canvas (bottom layer) -->
        <Canvas x:Name="AnimationCanvas" Background="#18000000"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

        <!-- Win info panel (top layer) — same blue/gold scheme as the Autocomplete
             banner (Background #1A44CC, yellow button) for consistency. -->
        <Border x:Name="WinInfoPanel"
                Background="#1A44CC" CornerRadius="12" Padding="48,32"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                BoxShadow="0 0 28 8 #90FFD700, 0 8 40 0 #80000000">
            <Grid>
                <StackPanel Spacing="10" HorizontalAlignment="Center">

                    <TextBlock Text="You win!"
                               FontSize="44" FontWeight="Black" Foreground="#FFD700"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"/>

                    <TextBlock x:Name="WinStatsLabel"
                               FontSize="18" Foreground="White"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"/>

                    <Button x:Name="PlayAgainButton"
                            Click="PlayAgain_Click"
                            HorizontalAlignment="Center"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Width="170" Height="46"
                            Margin="0,14,0,0"
                            Background="#FFD700"
                            Foreground="Black"
                            BorderThickness="0" CornerRadius="4">
                        <TextBlock Text="Play Again"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   FontSize="20" FontWeight="Bold"
                                   FontFamily="Segoe UI"/>
                    </Button>

                </StackPanel>
                <Button Classes="banner-close" Content="&#x2715;" Click="Close_Click" Margin="0,-20,-32,0"/>
            </Grid>
        </Border>
    </Grid>

</UserControl>
