<local:CardGameView xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SoliBee.Desktop.Views"
             x:Class="SoliBee.Desktop.Views.GameView"
             ClipToBounds="False">

    <Grid x:Name="BoardFeltGrid" ClipToBounds="False">
        <!-- Center container for the entire playing board, aligned towards the top to reduce space with the menu -->
        <StackPanel x:Name="BoardPanel" Width="1004" HorizontalAlignment="Center" VerticalAlignment="Top" Spacing="18" Margin="0,30,0,0" ClipToBounds="False">
            <!-- Top row: Stock, Waste, and Foundations, aligned to Grid columns -->
            <Grid x:Name="TopRowGrid" ColumnDefinitions="128,18,128,18,128,18,128,18,128,18,128,18,128" Width="1004" HorizontalAlignment="Center" ClipToBounds="False">
                <!-- Stock -->
                <local:PileView x:Name="StockPileControl" Grid.Column="0" Clicked="StockPileControl_Clicked" />

                <!-- Waste -->
                <local:PileView x:Name="WastePileControl" Grid.Column="2" />

                <!-- Foundations (aligned to Tableau Columns 4, 5, 6, 7) -->
                <local:PileView x:Name="Foundation0" Grid.Column="6" />
                <local:PileView x:Name="Foundation1" Grid.Column="8" />
                <local:PileView x:Name="Foundation2" Grid.Column="10" />
                <local:PileView x:Name="Foundation3" Grid.Column="12" />
            </Grid>

            <!-- Bottom row: Tableaus -->
            <Grid x:Name="TableauRowGrid" ColumnDefinitions="128,18,128,18,128,18,128,18,128,18,128,18,128" Width="1004" HorizontalAlignment="Center">
                <local:PileView x:Name="Tableau0" Grid.Column="0" />
                <local:PileView x:Name="Tableau1" Grid.Column="2" />
                <local:PileView x:Name="Tableau2" Grid.Column="4" />
                <local:PileView x:Name="Tableau3" Grid.Column="6" />
                <local:PileView x:Name="Tableau4" Grid.Column="8" />
                <local:PileView x:Name="Tableau5" Grid.Column="10" />
                <local:PileView x:Name="Tableau6" Grid.Column="12" />
            </Grid>
        </StackPanel>

        <!-- Keyboard hint row now lives in MainWindow's GameAreaGrid (SolitaireKeyHintLabel)
             so it's pinned to the true bottom of the window instead of the bottom of this
             board's own tight-fit content — see MainWindow.axaml for why. -->

        <!-- Global dragging canvas overlay -->
        <!-- HorizontalAlignment="Center" (not Stretch) — the board itself is horizontally
             centered in the window (MainContentWrapper) but only top-anchored vertically,
             so an oversized DragCanvas (sized to the real window, not the board's own
             tighter natural width — see SizeDragCanvasToWindow) needs to overflow
             symmetrically left/right around the board's own center to reach both true
             window edges, while Stretch's overflow-from-origin behavior already happens
             to reach the true bottom edge correctly since the board's top already equals
             the window's top. -->
        <Canvas x:Name="DragCanvas" IsHitTestVisible="False" Background="Transparent" HorizontalAlignment="Center" VerticalAlignment="Stretch" />

        <!-- Bouncing Card Cascade Overlay when won -->
        <local:WinAnimationView x:Name="VictoryOverlay" IsVisible="False" />

        <!-- Inline stuck banner -->
        <local:StuckBanner x:Name="NoMovesBanner" IsVisible="False"
                            NewGameClicked="NoMovesNewGame_Click"
                            RestartClicked="NoMovesRestart_Click"
                            DismissClicked="NoMovesDismiss_Click">
            <local:StuckBanner.ExtraContent>
                <!-- Klondike-only (Vegas mode): "Final bankroll: -$52.00" — #FFD600, body size -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" IsVisible="{Binding Options.IsVegasScoring}">
                    <TextBlock Text="Final bankroll: " Foreground="#FFD600" FontSize="14" FontFamily="Segoe UI" FontWeight="Bold"/>
                    <TextBlock Text="{Binding ScoreDisplay}" Foreground="#FFD600" FontSize="14" FontFamily="Segoe UI" FontWeight="Bold"/>
                </StackPanel>
            </local:StuckBanner.ExtraContent>
        </local:StuckBanner>

        <!-- Inline autocomplete banner -->
        <local:AutocompleteBanner x:Name="AutocompleteBanner" IsVisible="False"
                                   AutocompleteClicked="AutocompleteGame_Click"
                                   DismissClicked="AutocompleteDismiss_Click"/>

        <!-- Flashed when Hint has nothing to suggest -->
        <local:FlashToast x:Name="HintToast"/>

    </Grid>
</local:CardGameView>
