<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SoliBee.Desktop.Views.WinAnimationView">

    <!-- Transparent overlay canvas for hardware-accelerated composition animations -->
    <Canvas x:Name="AnimationCanvas" Background="#10000000" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
</UserControl>
