<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SoliBee.Desktop.Views"
        xmlns:vm="clr-namespace:SoliBee.Core.ViewModels;assembly=SoliBee.Core"
        x:Class="SoliBee.Desktop.Views.HoneycombDecksWindow"
        Title="Honeycomb Decks" Width="1000" Height="700"
        Background="#1E1E1E">
    
    <Grid ColumnDefinitions="*, 350">
        
        <!-- Left Side: Card Bank -->
        <Grid Grid.Column="0" RowDefinitions="Auto, *" Margin="20">
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,20">
                <TextBlock Text="Card Bank" FontSize="28" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" />
                <ComboBox x:Name="SortCombo" Width="120" SelectedIndex="0" Margin="20,0,0,0">
                    <ComboBoxItem Content="Sort: ID" />
                    <ComboBoxItem Content="Sort: Stars" />
                    <ComboBoxItem Content="Sort: Suit" />
                </ComboBox>
            </StackPanel>
            
            <ScrollViewer Grid.Row="1">
                <WrapPanel x:Name="BankPanel" ItemWidth="130" ItemHeight="170" />
            </ScrollViewer>
        </Grid>
        
        <!-- Right Side: Current Deck -->
        <Border Grid.Column="1" Background="#2A2A2A" Padding="20">
            <Grid RowDefinitions="Auto, *, Auto">
                <StackPanel Grid.Row="0" Spacing="10">
                    <TextBlock Text="Current Deck" FontSize="24" FontWeight="Bold" Foreground="White" />
                    <TextBlock x:Name="CapText" FontSize="18" Foreground="#FFD700" FontWeight="Bold" />
                    <TextBlock Text="Requires exactly 5 cards" FontSize="14" Foreground="#888888" />
                </StackPanel>
                
                <StackPanel x:Name="DeckPanel" Grid.Row="1" Spacing="10" Margin="0,20,0,0">
                    <!-- 5 slots populated in code-behind -->
                </StackPanel>
                
                <StackPanel Grid.Row="2" Spacing="10">
                    <TextBlock x:Name="ErrorText" Foreground="#FF5555" IsVisible="False" TextWrapping="Wrap" />
                    <Button x:Name="SaveButton" Content="Save &amp; Close" Background="#FFD700" Foreground="Black" FontWeight="Bold" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="15" Click="Save_Click" />
                </StackPanel>
            </Grid>
        </Border>
        
    </Grid>
</Window>
