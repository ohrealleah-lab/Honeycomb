<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SoliBee.Desktop.Views"
             x:Class="SoliBee.Desktop.Views.HoneycombView"
             ClipToBounds="False">

    <UserControl.Styles>
        <Style Selector="Button.honeycomb-action">
            <Setter Property="Background" Value="#FFD700" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="Button.honeycomb-action:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#FFEA00" />
            <Setter Property="Foreground" Value="Black" />
        </Style>
        <Style Selector="Button.honeycomb-blue">
            <Setter Property="Background" Value="#007AFF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="Button.honeycomb-blue:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#0062CC" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.manage-decks">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="White" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="36" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="Button.manage-decks:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#20FFFFFF" />
            <Setter Property="BorderBrush" Value="White" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </UserControl.Styles>

    <Grid Background="Transparent" ClipToBounds="False">
        <!-- Main Layout -->
        <Grid ColumnDefinitions="Auto, *, Auto, *, Auto" RowDefinitions="160, Auto" HorizontalAlignment="Center" VerticalAlignment="Center" ClipToBounds="False">
            
            <!-- Left Column: Player Hand (2-2-1 Pyramid) -->
            <Grid Grid.Column="0" Grid.Row="1" Width="410" Height="860" Margin="20" ClipToBounds="False">
                <TextBlock Text="PLAYER" Foreground="White" FontWeight="ExtraBold" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-35,0,0" Opacity="0.8"/>
                
                <local:HoneycombCardView x:Name="PlayerHand0" HorizontalAlignment="Left" VerticalAlignment="Top" />
                <local:HoneycombCardView x:Name="PlayerHand1" HorizontalAlignment="Right" VerticalAlignment="Top" />
                
                <local:HoneycombCardView x:Name="PlayerHand2" HorizontalAlignment="Left" VerticalAlignment="Center" />
                <local:HoneycombCardView x:Name="PlayerHand3" HorizontalAlignment="Right" VerticalAlignment="Center" />
                
                <local:HoneycombCardView x:Name="PlayerHand4" HorizontalAlignment="Center" VerticalAlignment="Bottom" />
                
                <!-- Turn indicator -->
                <Border x:Name="PlayerTurnIndicator" IsVisible="False" Background="Transparent" CornerRadius="10" Margin="-10" IsHitTestVisible="False" />
            </Grid>

            <!-- Center Column: Rules Banner or Steal Instruction -->
            <Border x:Name="RulesBannerBar" Grid.Row="0" Grid.Column="2" Background="#BF000000" CornerRadius="12" HorizontalAlignment="Center" VerticalAlignment="Bottom" Padding="24,18" Margin="0,0,0,20">
                <StackPanel Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Rules:" FontSize="28" FontWeight="Black" Foreground="#FFD600" HorizontalAlignment="Center" TextAlignment="Center" />
                    <ItemsControl x:Name="RulesList" HorizontalAlignment="Center">
                        <ItemsControl.Styles>
                            <Style Selector="ContentPresenter">
                                <Setter Property="HorizontalAlignment" Value="Center" />
                            </Style>
                        </ItemsControl.Styles>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="22" FontWeight="Black" Foreground="#FFD600" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,2,0,0" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Steal Instruction Bar (Replacing Rules Banner during Steal Mode) -->
            <Border x:Name="StealInstructionBar" Classes="banner-glow" Grid.Row="0" Grid.Column="2" Background="#BF000000" CornerRadius="12" IsVisible="False" HorizontalAlignment="Center" VerticalAlignment="Bottom" Padding="24,18" Margin="0,0,0,20">
                <StackPanel Spacing="12" HorizontalAlignment="Center">
                    <TextBlock x:Name="StealInstructionText" Text="Tap an opponent's card on the board to steal it." FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" />
                    <Button Classes="honeycomb-blue" Click="CancelSteal_Click" HorizontalAlignment="Center">
                        <TextBlock Text="Cancel" FontSize="16" FontWeight="Bold" FontFamily="Segoe UI"/>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Board (3x3 Grid) -->
            <Grid x:Name="BoardGrid" Grid.Row="1" Grid.Column="2" Width="600" Height="860" ColumnDefinitions="*,*,*" RowDefinitions="*,*,*" Margin="20" ClipToBounds="False">
                <!-- Placeholders and CardViews populated in code-behind -->
            </Grid>

            <!-- Right Column: Opponent Hand (2-2-1 Pyramid) -->
            <Grid Grid.Column="4" Grid.Row="1" Width="410" Height="860" Margin="20" ClipToBounds="False">
                <TextBlock Text="DEALER" Foreground="White" FontWeight="ExtraBold" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-35,0,0" Opacity="0.8"/>
                <local:HoneycombCardView x:Name="OpponentHand0" HorizontalAlignment="Left" VerticalAlignment="Top" />
                <local:HoneycombCardView x:Name="OpponentHand1" HorizontalAlignment="Right" VerticalAlignment="Top" />
                
                <local:HoneycombCardView x:Name="OpponentHand2" HorizontalAlignment="Left" VerticalAlignment="Center" />
                <local:HoneycombCardView x:Name="OpponentHand3" HorizontalAlignment="Right" VerticalAlignment="Center" />
                
                <local:HoneycombCardView x:Name="OpponentHand4" HorizontalAlignment="Center" VerticalAlignment="Bottom" />
                
                <!-- Turn indicator -->
                <Border x:Name="OpponentTurnIndicator" IsVisible="False" Background="Transparent" CornerRadius="10" Margin="-10" IsHitTestVisible="False" />
            </Grid>
        </Grid>

        <!-- Overlay: Post-match panels -->
        <Border x:Name="OverlayPanel" Classes="banner-glow" Background="#BF000000" CornerRadius="12" IsVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="32,24" MaxWidth="460" ZIndex="100">
            <Grid>
                <!-- Close Button -->
                <Button Content="✕" Click="CloseOverlay_Click" Classes="banner-close" Margin="0,-12,-12,0"/>
                
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16" Margin="0,10,0,0">
                    <TextBlock x:Name="OverlayTitle" Text="You Win!" FontSize="40" FontWeight="Black" Foreground="#FFD600" HorizontalAlignment="Center" FontFamily="Segoe UI" />
                    <!-- Subtitle hidden/removed as requested to match mockup -->
                    <TextBlock x:Name="OverlayLoseTitle" Text="Not today, partner!" FontSize="36" FontWeight="Black" Foreground="#FFD600" HorizontalAlignment="Center" FontFamily="Segoe UI" IsVisible="False" />
                    <TextBlock x:Name="OverlaySubtitle" Text="" FontSize="18" Foreground="#CCCCCC" HorizontalAlignment="Center" IsVisible="False" />
                    
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                        <Button x:Name="NewGameButton" Classes="honeycomb-blue" Click="NewGame_Click">
                            <TextBlock Text="New Game" FontSize="16" FontWeight="Bold" FontFamily="Segoe UI"/>
                        </Button>
                        <Button x:Name="RematchButton" Classes="honeycomb-blue" Click="Rematch_Click">
                            <TextBlock Text="Rematch" FontSize="16" FontWeight="Bold" FontFamily="Segoe UI"/>
                        </Button>
                        <Button x:Name="StealCardButton" Classes="honeycomb-action" Click="StealCard_Click" IsVisible="False">
                            <TextBlock Text="Steal Card" FontSize="16" FontWeight="Bold" FontFamily="Segoe UI"/>
                        </Button>
                    </StackPanel>
                    
                    <TextBlock x:Name="BankFullWarningText" Text="Your card bank is full. Start over in manage decks to steal again." IsVisible="False" FontSize="14" Foreground="#FF9999" HorizontalAlignment="Center" TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Swap Confirmation Panel -->
        <Border x:Name="SwapConfirmationPanel" Background="#80000000" IsVisible="False" ZIndex="110">
            <Border Background="#F2F2F7" CornerRadius="24" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="24" Width="340" BoxShadow="0 10 30 0 #40000000">
                <StackPanel Spacing="0">
                    <TextBlock Text="Swap Cards?" FontSize="18" FontWeight="Bold" Foreground="Black" Margin="0,0,0,12"/>
                    <TextBlock Text="You will replace one card in your active deck with the stolen card. Your other cards are unaffected." 
                               FontSize="15" Foreground="#333333" TextWrapping="Wrap" Margin="0,0,0,24" />
                    
                    <TextBlock x:Name="SwapErrorText" Text="" FontSize="14" Foreground="#FF3B30" IsVisible="False" Margin="0,0,0,16" TextWrapping="Wrap"/>
                    
                    <Grid ColumnDefinitions="*,12,*">
                        <Button Grid.Column="0" Content="Cancel" Foreground="Black" Background="#E5E5EA" BorderBrush="#A5C8FF" BorderThickness="3" CornerRadius="20" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Height="40" Click="CancelSwap_Click" FontWeight="SemiBold"/>
                        <Button Grid.Column="2" Content="Swap" Foreground="White" Background="#3B82F6" CornerRadius="20" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Height="40" Click="ConfirmSwap_Click" FontWeight="SemiBold"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <!-- Post-Steal Rematch Prompt -->
        <Border x:Name="RematchPromptPanel" Background="Transparent" IsVisible="False" ZIndex="110">
            <Border Classes="banner-glow" Background="#BF000000" CornerRadius="12" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="32,24" MaxWidth="460">
                <Grid>
                    <!-- Close button in top-right corner -->
                    <Button Content="✕" Click="CloseRematchPrompt_Click" Classes="banner-close" Margin="0,-12,-12,0"/>
                    
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16" Margin="0,10,0,0">
                        <TextBlock Text="New Game?" FontSize="36" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" FontFamily="Segoe UI"/>
                        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                            <Button Classes="honeycomb-blue" Click="RematchPrompt_Rematch_Click">
                                <TextBlock Text="Rematch" FontSize="16" FontWeight="Bold" FontFamily="Segoe UI"/>
                            </Button>
                            <Button Classes="honeycomb-blue" Click="RematchPrompt_NewGame_Click">
                                <TextBlock Text="New Game" FontSize="16" FontWeight="Bold" FontFamily="Segoe UI"/>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <!-- Score display removed, moved to title bar -->

        <Canvas x:Name="HoneycombDragCanvas" IsHitTestVisible="False" ZIndex="200" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ClipToBounds="False">
            <Border x:Name="CursorHighlightBorder" IsVisible="False" IsHitTestVisible="False"
                    BorderBrush="#00E5FF" BorderThickness="4" CornerRadius="8" Background="Transparent" />
        </Canvas>

        <!-- Rule Popups -->
        <local:FlashToast x:Name="RuleToast" ZIndex="250" IsHitTestVisible="False" />


    </Grid>
</UserControl>
