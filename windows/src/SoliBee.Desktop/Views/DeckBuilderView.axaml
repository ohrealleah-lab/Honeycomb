<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SoliBee.Desktop.Views"
        x:Class="SoliBee.Desktop.Views.DeckBuilderView"
        MinHeight="500" MinWidth="360"
        Background="White" CornerRadius="16">
        
    <UserControl.Styles>
        <Style Selector="Button.honeycomb-action">
            <Setter Property="Background" Value="#A0C0FF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="Button.honeycomb-action:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#7090E0" />
            <Setter Property="TextBlock.Foreground" Value="White" />
        </Style>
        <Style Selector="Button.honeycomb-cancel">
            <Setter Property="Background" Value="#E0E0E0" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#F0F0F0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10,5" />
        </Style>
    </UserControl.Styles>

    <!-- Root: fills whatever space the overlay gives it -->
    <Grid RowDefinitions="Auto, Auto, Auto, *, Auto" Margin="24,20,24,20">
        
        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Deck Builder" FontSize="28" FontWeight="Black"
                   HorizontalAlignment="Center" Margin="0,0,0,16" Foreground="#1A1A1A"/>
        
        <!-- Deck Name -->
        <TextBox Grid.Row="1" x:Name="DeckNameTextBox" MaxLength="20"
                 Watermark="Deck Name (Max 20 chars)" FontSize="16" Padding="10"
                 CornerRadius="8" BorderBrush="#80A0FF" BorderThickness="2"
                 HorizontalAlignment="Stretch" Margin="0,0,0,16"/>

        <!-- Your Deck Area -->
        <Border Grid.Row="2" Background="#EDF2F7" CornerRadius="12" Padding="16,12"
                Margin="0,0,0,16" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock x:Name="YourDeckTitle" Text="Your Deck (0/5) — Tap to Remove"
                           FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"
                           Margin="0,0,0,12" Foreground="#1A1A1A"/>
                <!-- Viewbox shrinks the 5-card row to fit narrower windows -->
                <Viewbox Stretch="Uniform" HorizontalAlignment="Center" MaxHeight="160">
                    <StackPanel x:Name="DeckSlotsPanel" Orientation="Horizontal" Spacing="10">
                        <!-- Populated in code-behind -->
                    </StackPanel>
                </Viewbox>
            </StackPanel>
        </Border>

        <!-- Card Bank Area -->
        <Grid Grid.Row="3" RowDefinitions="Auto, *">
            <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,10">
                <TextBlock Text="Card Bank — Tap to Add" FontSize="14" FontWeight="Bold" Foreground="#1A1A1A"/>
                <WrapPanel Orientation="Horizontal">
                    <ComboBox x:Name="StarsFilter" Width="110" Margin="0,0,8,4"
                              SelectionChanged="FilterCombo_SelectionChanged" SelectedIndex="0">
                        <ComboBoxItem Content="All Stars" />
                        <ComboBoxItem Content="1 Star" />
                        <ComboBoxItem Content="2 Stars" />
                        <ComboBoxItem Content="3 Stars" />
                        <ComboBoxItem Content="4 Stars" />
                        <ComboBoxItem Content="5 Stars" />
                    </ComboBox>
                    <ComboBox x:Name="SuitsFilter" Width="110" Margin="0,0,8,4"
                              SelectionChanged="FilterCombo_SelectionChanged" SelectedIndex="0">
                        <ComboBoxItem Content="All Suits" />
                        <ComboBoxItem Content="Spades" />
                        <ComboBoxItem Content="Hearts" />
                        <ComboBoxItem Content="Diamonds" />
                        <ComboBoxItem Content="Clubs" />
                    </ComboBox>
                    <ToggleButton x:Name="FavoritesFilter" Content="★ Favorites" CornerRadius="8"
                                  Background="#F0F0F0" Padding="10,5" Margin="0,0,0,4"
                                  Checked="FilterToggle_CheckedChanged"
                                  Unchecked="FilterToggle_CheckedChanged"/>
                </WrapPanel>
            </StackPanel>
            
            <ScrollViewer Grid.Row="1">
                <WrapPanel x:Name="BankPanel" ItemWidth="110" ItemHeight="155" Margin="0,8,0,0" />
            </ScrollViewer>
        </Grid>

        <!-- Buttons -->
        <Grid Grid.Row="4" ColumnDefinitions="*, Auto" Margin="0,16,0,0">
            <TextBlock x:Name="ErrorText" Grid.Column="0" Foreground="#FF5555"
                       FontSize="13" TextWrapping="Wrap" VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                <Button Content="Cancel" Classes="honeycomb-cancel" Click="Cancel_Click" />
                <Button x:Name="SaveButton" Content="Save Deck" Classes="honeycomb-action" Click="Save_Click" />
            </StackPanel>
        </Grid>
        
    </Grid>
</UserControl>
