<local:CardGameView xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SoliBee.Desktop.Views"
             x:Class="SoliBee.Desktop.Views.FreecellView"
             ClipToBounds="False">

    <Grid x:Name="BoardFeltGrid" ClipToBounds="False">
        <StackPanel Width="1066" HorizontalAlignment="Center" VerticalAlignment="Top" Spacing="18" Margin="0,10,0,0" ClipToBounds="False">

            <!-- Top row: 4 FreeCells (left) | 4 Foundations (right) -->
            <!-- ColDefs: 128,4,128,4,128,4,128,18,128,4,128,4,128,4,128 = 1066px -->
            <Grid ColumnDefinitions="128,4,128,4,128,4,128,18,128,4,128,4,128,4,128" Width="1066" HorizontalAlignment="Center" ClipToBounds="False">
                <local:PileView x:Name="FreeCell0" Grid.Column="0" />
                <local:PileView x:Name="FreeCell1" Grid.Column="2" />
                <local:PileView x:Name="FreeCell2" Grid.Column="4" />
                <local:PileView x:Name="FreeCell3" Grid.Column="6" />
                <local:PileView x:Name="Foundation0" Grid.Column="8" />
                <local:PileView x:Name="Foundation1" Grid.Column="10" />
                <local:PileView x:Name="Foundation2" Grid.Column="12" />
                <local:PileView x:Name="Foundation3" Grid.Column="14" />
            </Grid>

            <!-- Bottom row: 8 Tableaus -->
            <!-- ColDefs: 128,6,128,6,128,6,128,6,128,6,128,6,128,6,128 = 1066px -->
            <Grid ColumnDefinitions="128,6,128,6,128,6,128,6,128,6,128,6,128,6,128" Width="1066" HorizontalAlignment="Center">
                <local:PileView x:Name="Tableau0" Grid.Column="0" />
                <local:PileView x:Name="Tableau1" Grid.Column="2" />
                <local:PileView x:Name="Tableau2" Grid.Column="4" />
                <local:PileView x:Name="Tableau3" Grid.Column="6" />
                <local:PileView x:Name="Tableau4" Grid.Column="8" />
                <local:PileView x:Name="Tableau5" Grid.Column="10" />
                <local:PileView x:Name="Tableau6" Grid.Column="12" />
                <local:PileView x:Name="Tableau7" Grid.Column="14" />
            </Grid>

        </StackPanel>

        <!-- Drag overlay -->
        <Canvas x:Name="DragCanvas" IsHitTestVisible="False" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

        <!-- Win animation overlay -->
        <local:WinAnimationView x:Name="VictoryOverlay" IsVisible="False" />

        <!-- No-moves banner -->
        <Border x:Name="NoMovesBanner" IsVisible="False"
                Background="#CC000000" CornerRadius="8" Padding="20,12"
                HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,30">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="No more moves available." Foreground="White" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Text="Start a New Game to continue." Foreground="#AAFFFFFF" FontSize="13" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

    </Grid>

</local:CardGameView>
