<local:CardGameView xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SoliBee.Desktop.Views"
             x:Class="SoliBee.Desktop.Views.GameView"
             ClipToBounds="False">

    <Grid x:Name="BoardFeltGrid" ClipToBounds="False">
        <!-- Center container for the entire playing board, aligned towards the top to reduce space with the menu -->
        <StackPanel x:Name="BoardPanel" Width="1004" HorizontalAlignment="Center" VerticalAlignment="Top" Spacing="18" Margin="0,30,0,0" ClipToBounds="False">
            <!-- Top row: Stock, Waste, and Foundations, aligned to Grid columns -->
            <Grid x:Name="TopRowGrid" ColumnDefinitions="128,18,128,18,128,18,128,18,128,18,128,18,128" Width="1004" HorizontalAlignment="Center" ClipToBounds="False">
                <!-- Stock -->
                <local:PileView x:Name="StockPileControl" Grid.Column="0" Clicked="StockPileControl_Clicked" />

                <!-- Waste -->
                <local:PileView x:Name="WastePileControl" Grid.Column="2" />

                <!-- Foundations (aligned to Tableau Columns 4, 5, 6, 7) -->
                <local:PileView x:Name="Foundation0" Grid.Column="6" />
                <local:PileView x:Name="Foundation1" Grid.Column="8" />
                <local:PileView x:Name="Foundation2" Grid.Column="10" />
                <local:PileView x:Name="Foundation3" Grid.Column="12" />
            </Grid>

            <!-- Bottom row: Tableaus -->
            <Grid x:Name="TableauRowGrid" ColumnDefinitions="128,18,128,18,128,18,128,18,128,18,128,18,128" Width="1004" HorizontalAlignment="Center">
                <local:PileView x:Name="Tableau0" Grid.Column="0" />
                <local:PileView x:Name="Tableau1" Grid.Column="2" />
                <local:PileView x:Name="Tableau2" Grid.Column="4" />
                <local:PileView x:Name="Tableau3" Grid.Column="6" />
                <local:PileView x:Name="Tableau4" Grid.Column="8" />
                <local:PileView x:Name="Tableau5" Grid.Column="10" />
                <local:PileView x:Name="Tableau6" Grid.Column="12" />
            </Grid>
        </StackPanel>

        <!-- Keyboard hint row — same styling/placement convention as Blackjack/Video
             Poker's KeyHintLabel, anchored to the bottom of the board. -->
        <TextBlock x:Name="KeyHintLabel"
                   Text="Arrows=Move Cursor   Space/Return=Select or Move   D=Draw   F=Auto-Foundation   A=Autocomplete   Esc=Clear Cursor"
                   FontSize="10" Foreground="#90FFFFFF" HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   FontFamily="Segoe UI"
                   Margin="0,4,0,8"/>

        <!-- Global dragging canvas overlay -->
        <Canvas x:Name="DragCanvas" IsHitTestVisible="False" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

        <!-- Bouncing Card Cascade Overlay when won -->
        <local:WinAnimationView x:Name="VictoryOverlay" IsVisible="False" />

        <!-- Inline stuck banner -->
        <Grid x:Name="NoMovesBanner" IsVisible="False" ZIndex="5" HorizontalAlignment="Center" VerticalAlignment="Center">
            <!-- Banner card. Classes="banner-glow" (App.axaml) applies the shared static
                 soft gold halo (no offset, 16px blur, 50% opacity — matches the Mac
                 original's .shadow(color: gold.opacity(0.5), radius: 16)). -->
            <Border Classes="banner-glow" Background="#BF000000" CornerRadius="12" Padding="24,24" MaxWidth="320">
                <StackPanel Spacing="12" HorizontalAlignment="Center">
                    <TextBlock Text="Game Over" FontSize="36" FontWeight="Black"
                               Foreground="#FFD600" HorizontalAlignment="Center" FontFamily="Segoe UI"
                               TextAlignment="Center"/>
                    
                    <TextBlock Text="No moves remaining." FontSize="14" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" FontFamily="Segoe UI"
                               TextAlignment="Center"/>
                    
                    <!-- Hidden label to compile with code-behind -->
                    <TextBlock x:Name="NoMovesStatsLabel" IsVisible="False" />
                    
                    <!-- Optional line (Vegas mode only): "Final bankroll: -$52.00" — #FFD600, body size -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" IsVisible="{Binding Options.IsVegasScoring}">
                        <TextBlock Text="Final bankroll: " Foreground="#FFD600" FontSize="14" FontFamily="Segoe UI" FontWeight="Bold"/>
                        <TextBlock Text="{Binding ScoreDisplay}" Foreground="#FFD600" FontSize="14" FontFamily="Segoe UI" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                        <Button Classes="banner-action" Content="New Game" Click="NoMovesNewGame_Click"/>
                        <Button Classes="banner-action" Content="Restart Game" Click="NoMovesRestart_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <!-- Dismiss button anchored TopRight, overlapping corner -->
            <Button Width="20" Height="20" Padding="0" Background="Transparent" BorderThickness="0"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0"
                    Foreground="#B3FFFFFF" FontSize="16" Content="✕" Click="NoMovesDismiss_Click"/>
        </Grid>

        <!-- Inline autocomplete banner -->
        <Grid x:Name="AutocompleteBanner" IsVisible="False" ZIndex="5" HorizontalAlignment="Center" VerticalAlignment="Center">
            <!-- Banner card. Classes="banner-glow" (App.axaml) applies the shared static
                 soft gold halo (no offset, 16px blur, 50% opacity — matches the Mac
                 original's .shadow(color: gold.opacity(0.5), radius: 16)). -->
            <Border Classes="banner-glow" Background="#BF000000" CornerRadius="12" Padding="24,24" MaxWidth="400">
                <StackPanel Spacing="12" HorizontalAlignment="Center">
                    <TextBlock Text="Victory is guaranteed!" FontSize="36" FontWeight="Black"
                               Foreground="#FFD600" HorizontalAlignment="Center" FontFamily="Segoe UI"
                               TextAlignment="Center" TextWrapping="Wrap"/>
                    <TextBlock Text="All remaining cards can be moved to foundations."
                               FontSize="14" Foreground="White" HorizontalAlignment="Center"
                               FontFamily="Segoe UI" TextAlignment="Center" TextWrapping="Wrap"/>
                    <Button Classes="banner-action" Content="Autocomplete Game" Click="AutocompleteGame_Click"
                            HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <!-- Dismiss button anchored TopRight, overlapping corner -->
            <Button Width="20" Height="20" Padding="0" Background="Transparent" BorderThickness="0"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0"
                    Foreground="#B3FFFFFF" FontSize="16" Content="✕" Click="AutocompleteDismiss_Click"/>
        </Grid>

    </Grid>
</local:CardGameView>
