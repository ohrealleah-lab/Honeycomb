<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SoliBee.Desktop.Views"
             x:Class="SoliBee.Desktop.Views.VideoPokerView">

    <Grid x:Name="BoardFeltGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Vignette depth overlay -->
        <Rectangle Grid.ColumnSpan="2" IsHitTestVisible="False" ZIndex="-1">
            <Rectangle.Fill>
                <RadialGradientBrush Center="50%,50%" Radius="0.8">
                    <GradientStop Color="#00000000" Offset="0.2"/>
                    <GradientStop Color="#30000000" Offset="1.0"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- ─── Pay Table Panel ─────────────────────────────────────────── -->
        <Border Grid.Column="0" Padding="10,14,8,14"
                BorderBrush="#25FFFFFF" BorderThickness="0,0,1,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                    <GradientStop Color="#30000000" Offset="0"/>
                    <GradientStop Color="#15000000" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel Spacing="0">

                <!-- Variant selector -->
                <ComboBox x:Name="VariantComboBox"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Center"
                          SelectionChanged="VariantComboBox_SelectionChanged"
                          Margin="0,0,0,8">
                    <ComboBoxItem Content="Jacks or Better"/>
                    <ComboBoxItem Content="Deuces Wild"/>
                    <ComboBoxItem Content="Bonus Poker"/>
                </ComboBox>

                <!-- Column headers -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="34"/>
                        <ColumnDefinition Width="34"/>
                        <ColumnDefinition Width="34"/>
                        <ColumnDefinition Width="34"/>
                        <ColumnDefinition Width="34"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="HAND" FontSize="13" Foreground="#60FFFFFF"
                               FontFamily="Courier New, Consolas, monospace" Grid.Column="0"/>
                    <TextBlock x:Name="PayColHdr1" Text="1" FontSize="13" Foreground="#60FFFFFF"
                               FontFamily="Courier New, Consolas, monospace"
                               Grid.Column="1" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="PayColHdr2" Text="2" FontSize="13" Foreground="#60FFFFFF"
                               FontFamily="Courier New, Consolas, monospace"
                               Grid.Column="2" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="PayColHdr3" Text="3" FontSize="13" Foreground="#60FFFFFF"
                               FontFamily="Courier New, Consolas, monospace"
                               Grid.Column="3" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="PayColHdr4" Text="4" FontSize="13" Foreground="#60FFFFFF"
                               FontFamily="Courier New, Consolas, monospace"
                               Grid.Column="4" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="PayColHdr5" Text="5" FontSize="13" Foreground="#60FFFFFF"
                               FontFamily="Courier New, Consolas, monospace"
                               Grid.Column="5" HorizontalAlignment="Center"/>
                </Grid>

                <StackPanel x:Name="PayTablePanel" Spacing="1"/>

            </StackPanel>
        </Border>

        <!-- ─── Game Area ───────────────────────────────────────────────── -->
        <Grid Grid.Column="1">

            <!-- All game content vertically + horizontally centered in the game column -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="0">

                <!-- Hold prompt: reserve fixed height so cards don't shift when it appears -->
                <Border Height="46" Margin="0,0,0,10">
                    <TextBlock Text="How many cards, partner?"
                               FontSize="26" FontWeight="Bold"
                               Foreground="White" Opacity="0.85"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsVisible="{Binding IsHolding}"/>
                </Border>

                <!-- Cards + overlays (layered Grid) -->
                <Grid>

                    <!-- Card slots + hold badges -->
                    <StackPanel x:Name="CardsRow" Orientation="Horizontal" Spacing="0" HorizontalAlignment="Center">

                        <Grid x:Name="CardSlot0" Width="128" Height="181"
                              Tag="0" Background="Transparent" PointerPressed="CardSlot_PointerPressed">
                            <local:CardView x:Name="Card0View" IsHitTestVisible="False" Width="128" Height="181"/>
                        </Grid>

                        <Grid x:Name="CardSlot1" Width="128" Height="181" Margin="-24,0,0,0"
                              Tag="1" Background="Transparent" PointerPressed="CardSlot_PointerPressed">
                            <local:CardView x:Name="Card1View" IsHitTestVisible="False" Width="128" Height="181"/>
                        </Grid>

                        <Grid x:Name="CardSlot2" Width="128" Height="181" Margin="-24,0,0,0"
                              Tag="2" Background="Transparent" PointerPressed="CardSlot_PointerPressed">
                            <local:CardView x:Name="Card2View" IsHitTestVisible="False" Width="128" Height="181"/>
                        </Grid>

                        <Grid x:Name="CardSlot3" Width="128" Height="181" Margin="-24,0,0,0"
                              Tag="3" Background="Transparent" PointerPressed="CardSlot_PointerPressed">
                            <local:CardView x:Name="Card3View" IsHitTestVisible="False" Width="128" Height="181"/>
                        </Grid>

                        <Grid x:Name="CardSlot4" Width="128" Height="181" Margin="-24,0,0,0"
                              Tag="4" Background="Transparent" PointerPressed="CardSlot_PointerPressed">
                            <local:CardView x:Name="Card4View" IsHitTestVisible="False" Width="128" Height="181"/>
                        </Grid>

                    </StackPanel>

                    <!-- Overlay layer: spans card-face height only (181px) so banners center over faces -->
                    <Grid Height="181" VerticalAlignment="Top">

                        <!-- No-win overlay -->
                        <Border x:Name="NoWinOverlay" IsVisible="False"
                                Background="#1A44CC" CornerRadius="8" Padding="32,14"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                BoxShadow="0 4 18 0 #AA000000"
                                IsHitTestVisible="True"
                                PointerPressed="NoWinOverlay_PointerPressed">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Not today, partner!"
                                           FontSize="30" FontWeight="Black" Foreground="White"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Ante up!"
                                           FontSize="22" FontWeight="Bold" Foreground="White" Opacity="0.80"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Win overlay -->
                        <Border x:Name="WinBanner"
                                IsVisible="False"
                                Background="#1A44CC" CornerRadius="8" Padding="32,14"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                BoxShadow="0 0 28 8 #90FFD700, 0 4 18 0 #AA000000"
                                RenderTransformOrigin="50%,50%"
                                IsHitTestVisible="True"
                                PointerPressed="WinBanner_PointerPressed">
                            <StackPanel Spacing="6">
                                <TextBlock x:Name="WinHandNameBlock"
                                           FontSize="30" FontWeight="Black" Foreground="#FFD700"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="WinPayoutBlock"
                                           FontSize="22" FontWeight="Bold" Foreground="White" Opacity="0.80"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                    </Grid>

                </Grid>

                <!-- Gap -->
                <Border Height="14"/>

                <!-- Buttons -->
                <StackPanel x:Name="ButtonRow" Orientation="Horizontal" Spacing="10"
                            HorizontalAlignment="Center" Margin="0,0,0,10">
                    <Button x:Name="DealDrawButton"
                            Content="Deal" Height="52" Padding="32,0"
                            Click="DealDraw_Click" Classes="vp-button vp-button-primary"/>
                    <Button Content="− Bet" Height="52" Padding="16,0"
                            IsEnabled="{Binding IsDealing}"
                            Click="DecreaseBet_Click" Classes="vp-button"/>
                    <Button Content="Bet Max" Height="52" Padding="16,0"
                            IsEnabled="{Binding IsDealing}"
                            Click="BetMax_Click" Classes="vp-button"/>
                    <Button Content="+ Bet" Height="52" Padding="16,0"
                            IsEnabled="{Binding IsDealing}"
                            Click="IncreaseBet_Click" Classes="vp-button"/>
                    <Button x:Name="RebuyButton"
                            Content="Buy In" Height="52" Padding="16,0"
                            IsVisible="False"
                            Click="Rebuy_Click" Classes="vp-button vp-button-rebuy"/>
                </StackPanel>

                <!-- Credits + Bet, centered under buttons -->
                <StackPanel Orientation="Horizontal" Spacing="40" HorizontalAlignment="Center">
                    <StackPanel Spacing="2">
                        <TextBlock Text="CREDITS" FontSize="10" FontWeight="Bold" Foreground="#70FFFFFF"/>
                        <TextBlock x:Name="CreditsLabel"
                                   FontSize="28" FontWeight="Black" Foreground="White" MinWidth="80"/>
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <TextBlock Text="BET" FontSize="10" FontWeight="Bold" Foreground="#70FFFFFF"/>
                        <TextBlock x:Name="BetLabel"
                                   FontSize="28" FontWeight="Black" Foreground="#FFD700" MinWidth="40"/>
                    </StackPanel>
                </StackPanel>

            </StackPanel>

        </Grid>
    </Grid>

    <UserControl.Styles>
        <Style Selector="Button.vp-button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                        <GradientStop Color="#65FFFFFF" Offset="0"/>
                        <GradientStop Color="#35FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#A0FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.vp-button:pointerover /template/ ContentPresenter">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                        <GradientStop Color="#85FFFFFF" Offset="0"/>
                        <GradientStop Color="#55FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>
        <Style Selector="Button.vp-button-primary">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                        <GradientStop Color="#DD3A77DD" Offset="0"/>
                        <GradientStop Color="#CC1144AA" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#AADDEEFF"/>
        </Style>
        <Style Selector="Button.vp-button-primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                        <GradientStop Color="#DD4A88EE" Offset="0"/>
                        <GradientStop Color="#CC2255BB" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>
        <Style Selector="Button.vp-button-rebuy">
            <Setter Property="Background" Value="#CC664400"/>
            <Setter Property="BorderBrush" Value="#FFAA44"/>
        </Style>
        <Style Selector="ComboBox#VariantComboBox">
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="Foreground" Value="#FFD700"/>
            <Setter Property="BorderBrush" Value="#44FFD700"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Courier New, Consolas, monospace"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </UserControl.Styles>

</UserControl>
