<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SoliBee.Desktop.Views.AboutWindow"
        Title="About SoliBee"
        Width="340" Height="220"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        ShowInTaskbar="False">

    <Grid RowDefinitions="*, Auto">
        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="6" Margin="32,24,32,12">

            <TextBlock Text="SoliBee"
                       FontSize="32" FontWeight="Black"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       FontFamily="Courier New, Consolas, monospace" />

            <TextBlock Text="Solitaire Suite"
                       FontSize="13" FontWeight="SemiBold"
                       Foreground="#A0A0A0"
                       HorizontalAlignment="Center"
                       LetterSpacing="2" />

            <Border Height="1" Background="#333333" Margin="0,6,0,6" />

            <TextBlock x:Name="VersionText"
                       FontSize="12" Foreground="#C0C0C0"
                       HorizontalAlignment="Center" />

            <TextBlock Text="© 2026 Leahbee. All rights reserved."
                       FontSize="11" Foreground="#808080"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <Button Grid.Row="1"
                Content="Close"
                Click="Close_Click"
                HorizontalAlignment="Right"
                Margin="0,0,20,16"
                Width="80"
                HorizontalContentAlignment="Center"
                Background="#444444"
                Foreground="White" />
    </Grid>
</Window>
