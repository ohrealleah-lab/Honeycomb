<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SoliBee.Desktop.Views.HoneycombRulesWindow"
        Title="Honeycomb Rules" Width="550" Height="480"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="#F4F4F4" CanResize="False">

    
    <Grid RowDefinitions="*,Auto" Margin="20">
        <Grid ColumnDefinitions="*,*" Margin="0,0,0,20">
            <!-- Left Column: Game Choice -->
            <StackPanel Grid.Column="0" Margin="0,0,20,0" Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,10">
                    <TextBlock Text="Difficulty:" FontSize="13" FontWeight="SemiBold" Foreground="#1A1A1A" VerticalAlignment="Center"/>
                    <ComboBox x:Name="HoneycombDifficultyCombo" Width="100" SelectionChanged="HoneycombDifficultyCombo_SelectionChanged">
                        <ComboBoxItem Content="Easy" Tag="Easy"/>
                        <ComboBoxItem Content="Medium" Tag="Medium"/>
                        <ComboBoxItem Content="Hard" Tag="Hard"/>
                        <ComboBoxItem Content="Ultra Hard" Tag="UltraHard"/>
                    </ComboBox>
                </StackPanel>

                <TextBlock Text="Game Choice" FontSize="16" FontWeight="Bold" Foreground="#1A1A1A" Margin="0,0,0,2"/>
                
                <TextBlock Text="Select up to 2 rules. Leave empty (and Normal Mode off) to let roulette decide each match — including occasionally rolling no rules at all." 
                           FontSize="11" Foreground="#707070" TextWrapping="Wrap" Margin="0,0,0,6"/>

                <StackPanel x:Name="HoneycombRulesPanel" Spacing="2">
                    <CheckBox x:Name="HoneycombRule_ForceNormal" Content="Normal Mode (Force Zero Rules)" Tag="ForceNormal" Checked="HoneycombRule_Changed" Unchecked="HoneycombRule_Changed" Foreground="#1A1A1A"/>
                    <CheckBox x:Name="HoneycombRule_Ascension" Content="Ascension" Tag="Ascension" Checked="HoneycombRule_Changed" Unchecked="HoneycombRule_Changed" Foreground="#1A1A1A"/>
                    <CheckBox x:Name="HoneycombRule_Descension" Content="Descension" Tag="Descension" Checked="HoneycombRule_Changed" Unchecked="HoneycombRule_Changed" Foreground="#1A1A1A"/>
                    <CheckBox x:Name="HoneycombRule_Same" Content="Same" Tag="Same" Checked="HoneycombRule_Changed" Unchecked="HoneycombRule_Changed" Foreground="#1A1A1A"/>
                    <CheckBox x:Name="HoneycombRule_Plus" Content="Plus" Tag="Plus" Checked="HoneycombRule_Changed" Unchecked="HoneycombRule_Changed" Foreground="#1A1A1A"/>
                    <CheckBox x:Name="HoneycombRule_FallenAce" Content="Fallen Ace" Tag="FallenAce" Checked="HoneycombRule_Changed" Unchecked="HoneycombRule_Changed" Foreground="#1A1A1A"/>
                    <CheckBox x:Name="HoneycombRule_AllOpen" Content="All Open" Tag="AllOpen" Checked="HoneycombRule_Changed" Unchecked="HoneycombRule_Changed" Foreground="#1A1A1A"/>
                    <CheckBox x:Name="HoneycombRule_ThreeOpen" Content="Three Open" Tag="ThreeOpen" Checked="HoneycombRule_Changed" Unchecked="HoneycombRule_Changed" Foreground="#1A1A1A"/>
                    <CheckBox x:Name="HoneycombRule_Swap" Content="Swap" Tag="Swap" Checked="HoneycombRule_Changed" Unchecked="HoneycombRule_Changed" Foreground="#1A1A1A"/>
                    <CheckBox x:Name="HoneycombRule_Order" Content="Order" Tag="Order" Checked="HoneycombRule_Changed" Unchecked="HoneycombRule_Changed" Foreground="#1A1A1A"/>
                    <CheckBox x:Name="HoneycombRule_Chaos" Content="Chaos" Tag="Chaos" Checked="HoneycombRule_Changed" Unchecked="HoneycombRule_Changed" Foreground="#1A1A1A"/>
                </StackPanel>
            </StackPanel>

            <!-- Right Column: Ban List -->
            <StackPanel Grid.Column="1" Margin="20,0,0,0" Spacing="6">
                <TextBlock Text="Ban List" FontSize="16" FontWeight="Bold" Foreground="#1A1A1A" Margin="0,38,0,2"/>
                
                <TextBlock Text="Select games to ban from roulettes." FontSize="11" Foreground="#707070" TextWrapping="Wrap" Margin="0,0,0,6"/>
                
                <StackPanel Spacing="2">
                    <CheckBox x:Name="Ban_NormalMode" Content="Normal Mode" Tag="Normal Mode" Checked="BanRule_Changed" Unchecked="BanRule_Changed" Foreground="#1A1A1A"/>
                    <CheckBox x:Name="Ban_Ascension" Content="Ascension" Tag="Ascension" Checked="BanRule_Changed" Unchecked="BanRule_Changed" Foreground="#1A1A1A"/>
                    <CheckBox x:Name="Ban_Descension" Content="Descension" Tag="Descension" Checked="BanRule_Changed" Unchecked="BanRule_Changed" Foreground="#1A1A1A"/>
                    <CheckBox x:Name="Ban_Same" Content="Same" Tag="Same" Checked="BanRule_Changed" Unchecked="BanRule_Changed" Foreground="#1A1A1A"/>
                    <CheckBox x:Name="Ban_Plus" Content="Plus" Tag="Plus" Checked="BanRule_Changed" Unchecked="BanRule_Changed" Foreground="#1A1A1A"/>
                    <CheckBox x:Name="Ban_FallenAce" Content="Fallen Ace" Tag="Fallen Ace" Checked="BanRule_Changed" Unchecked="BanRule_Changed" Foreground="#1A1A1A"/>
                    <CheckBox x:Name="Ban_AllOpen" Content="All Open" Tag="All Open" Checked="BanRule_Changed" Unchecked="BanRule_Changed" Foreground="#1A1A1A"/>
                    <CheckBox x:Name="Ban_ThreeOpen" Content="Three Open" Tag="Three Open" Checked="BanRule_Changed" Unchecked="BanRule_Changed" Foreground="#1A1A1A"/>
                    <CheckBox x:Name="Ban_Swap" Content="Swap" Tag="Swap" Checked="BanRule_Changed" Unchecked="BanRule_Changed" Foreground="#1A1A1A"/>
                    <CheckBox x:Name="Ban_Order" Content="Order" Tag="Order" Checked="BanRule_Changed" Unchecked="BanRule_Changed" Foreground="#1A1A1A"/>
                    <CheckBox x:Name="Ban_Chaos" Content="Chaos" Tag="Chaos" Checked="BanRule_Changed" Unchecked="BanRule_Changed" Foreground="#1A1A1A"/>
                    <CheckBox x:Name="Ban_Reverse" Content="Reverse" Tag="Reverse" Checked="BanRule_Changed" Unchecked="BanRule_Changed" Foreground="#1A1A1A"/>
                </StackPanel>
                
                <TextBlock x:Name="SillyBeeWarning" Text="You cannot blacklist every game, silly bee." FontSize="11" FontWeight="SemiBold" Foreground="#E53935" IsVisible="False" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>
        
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
            <Button Content="Cancel" Click="Cancel_Click" Width="80" HorizontalContentAlignment="Center"/>
            <Button Content="OK" Click="OK_Click" Width="80" HorizontalContentAlignment="Center" Background="#0078D7" Foreground="White" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>
