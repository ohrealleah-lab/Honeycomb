<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SoliBee.Desktop.Views.CardBackEditorWindow"
        Title="Edit Card Back"
        Width="340" Height="500"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        ShowInTaskbar="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Card back preview -->
        <Border Grid.Row="0" HorizontalAlignment="Center" Margin="0,18,0,12">
            <Border Width="128" Height="181"
                    BorderBrush="#D9000000" BorderThickness="0.75"
                    CornerRadius="10" ClipToBounds="True"
                    BoxShadow="0 2 8 0 #40000000" Background="White">
                <Grid Width="128" Height="181" ClipToBounds="True">
                    <Image x:Name="PreviewImage" />
                </Grid>
            </Border>
        </Border>

        <!-- Sliders (hidden for Dingwall) -->
        <StackPanel x:Name="SliderPanel" Grid.Row="1" Spacing="5" Margin="20,0">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="Scale:" Foreground="White" FontSize="12" FontWeight="SemiBold" Width="110" VerticalAlignment="Center" />
                <TextBlock x:Name="ScaleValueText" Text="1.00" Foreground="#C0C0C0" FontSize="12" VerticalAlignment="Center" />
            </StackPanel>
            <Slider x:Name="ScaleSlider" Minimum="0.1" Maximum="3.0" Value="1.0"
                    ValueChanged="Slider_Changed" />

            <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="Horizontal Offset:" Foreground="White" FontSize="12" FontWeight="SemiBold" Width="110" VerticalAlignment="Center" />
                <TextBlock x:Name="OffsetXValueText" Text="0" Foreground="#C0C0C0" FontSize="12" VerticalAlignment="Center" />
            </StackPanel>
            <Slider x:Name="OffsetXSlider" Minimum="-100" Maximum="100" Value="0"
                    ValueChanged="Slider_Changed" />

            <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="Vertical Offset:" Foreground="White" FontSize="12" FontWeight="SemiBold" Width="110" VerticalAlignment="Center" />
                <TextBlock x:Name="OffsetYValueText" Text="0" Foreground="#C0C0C0" FontSize="12" VerticalAlignment="Center" />
            </StackPanel>
            <Slider x:Name="OffsetYSlider" Minimum="-100" Maximum="100" Value="0"
                    ValueChanged="Slider_Changed" />
        </StackPanel>

        <!-- Note shown instead of sliders for fill-type themes -->
        <TextBlock x:Name="FillNote" Grid.Row="1"
                   Text="This card back fills the card automatically&#x0a;and doesn't use position adjustments."
                   Foreground="#808080" FontSize="11" TextWrapping="Wrap"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   TextAlignment="Center" Margin="20,0"
                   IsVisible="False" />

        <!-- Save / Cancel -->
        <Grid Grid.Row="2" ColumnDefinitions="*,*" Margin="20,12,20,20">
            <Button Content="Cancel" Click="Cancel_Click" Grid.Column="0"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Background="#444444" Foreground="White" Margin="0,0,4,0" />
            <Button Content="Save" Click="Save_Click" Grid.Column="1"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Background="#226622" Foreground="White" Margin="4,0,0,0" />
        </Grid>
    </Grid>
</Window>
