<Window
    x:Class="SoliBee.Desktop.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SoliBee.Desktop.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="SoliBee Solitaire Suite">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Command Bar/Navigation -->
        <CommandBar Grid.Row="0">
            <AppBarButton Icon="Play" Label="New Game" Click="NewGame_Click" />
            <AppBarButton Icon="Undo" Label="Undo" Click="Undo_Click" />
            <AppBarButton Icon="Settings" Label="Preferences" Click="Preferences_Click" />
            <AppBarSeparator />
            <AppBarButton Icon="Target" Label="Autocomplete" Click="Autocomplete_Click" />
        </CommandBar>

        <!-- Main Game Area -->
        <ContentControl x:Name="MainContent" Grid.Row="1" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
    </Grid>
</Window>
