<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SoliBee.Desktop.Views"
             x:Class="SoliBee.Desktop.Views.ManageDecksView"
             MinHeight="500" MinWidth="400">

    <UserControl.Styles>
        <Style Selector="Button.btn-blue">
            <Setter Property="Background" Value="#5B8DEF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="Button.btn-blue:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3D6DD4"/>
        </Style>
        <Style Selector="Button.btn-red">
            <Setter Property="Background" Value="#E05050"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="Button.btn-red:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#B03030"/>
        </Style>
        <Style Selector="Button.btn-gray">
            <Setter Property="Background" Value="#D0D0D0"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="ToggleButton.heart-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="2"/>
        </Style>
        <Style Selector="ToggleButton.heart-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ToggleButton.heart-btn:checked /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#F2F2F2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
    </UserControl.Styles>

    <!-- Outer grid: content + overlay -->
    <Grid>

        <!-- Main Two-Column Layout -->
        <Grid ColumnDefinitions="*, *" Margin="16">

            <!-- LEFT: Saved Decks -->
            <Grid Grid.Column="0" RowDefinitions="Auto, *, Auto" Margin="0,0,10,0">

                <TextBlock Grid.Row="0" Text="SAVED DECKS"
                           FontSize="12" FontWeight="Bold" Foreground="#888"
                           Margin="0,0,0,12"/>

                <ScrollViewer Grid.Row="1">
                    <StackPanel x:Name="DecksListPanel" Spacing="10"/>
                </ScrollViewer>

                <!-- Start Over -->
                <Border Grid.Row="2" Background="#C0392B" CornerRadius="10"
                        Padding="16,12" Margin="0,16,0,0">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Start over clears your decks and card bank, then reseeds the game."
                                   FontSize="12" Foreground="White" TextWrapping="Wrap"/>
                        <Button Content="Start Over" Classes="btn-red"
                                HorizontalAlignment="Left" Click="StartOver_Click"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Divider -->
            <Rectangle Grid.Column="0" Width="1" Fill="#E0E0E0"
                       HorizontalAlignment="Right" VerticalAlignment="Stretch" Margin="0,0,0,0"/>

            <!-- RIGHT: Card Bank -->
            <Grid Grid.Column="1" RowDefinitions="Auto, Auto, *" Margin="10,0,0,0">

                <TextBlock x:Name="CardBankTitle" Grid.Row="0"
                           Text="CARD BANK" FontSize="12" FontWeight="Bold"
                           Foreground="#888" Margin="0,0,0,10"/>

                <!-- Filters -->
                <WrapPanel Grid.Row="1" Margin="0,0,0,10">
                    <ComboBox x:Name="StarsFilter" Width="105" Margin="0,0,6,6"
                              SelectionChanged="FilterCombo_SelectionChanged" SelectedIndex="0">
                        <ComboBoxItem Content="All Stars"/>
                        <ComboBoxItem Content="1 Star"/>
                        <ComboBoxItem Content="2 Stars"/>
                        <ComboBoxItem Content="3 Stars"/>
                        <ComboBoxItem Content="4 Stars"/>
                        <ComboBoxItem Content="5 Stars"/>
                    </ComboBox>
                    <ComboBox x:Name="SuitsFilter" Width="105" Margin="0,0,6,6"
                              SelectionChanged="FilterCombo_SelectionChanged" SelectedIndex="0">
                        <ComboBoxItem Content="All Suits"/>
                        <ComboBoxItem Content="Spades"/>
                        <ComboBoxItem Content="Hearts"/>
                        <ComboBoxItem Content="Diamonds"/>
                        <ComboBoxItem Content="Clubs"/>
                    </ComboBox>
                    <ToggleButton x:Name="FavoritesFilter" Content="♡ Favorites"
                                  CornerRadius="8" Background="#F0F0F0" Padding="8,4"
                                  Margin="0,0,0,6"
                                  Checked="FilterToggle_CheckedChanged"
                                  Unchecked="FilterToggle_CheckedChanged"/>
                </WrapPanel>

                <ScrollViewer Grid.Row="2">
                    <WrapPanel x:Name="BankPanel" ItemWidth="90" ItemHeight="128"/>
                </ScrollViewer>
            </Grid>

        </Grid>

        <!-- Start Over Confirmation Overlay -->
        <Grid x:Name="StartOverOverlay" Background="#99000000" IsVisible="False" ZIndex="200">
            <Border Background="White" CornerRadius="12" Padding="28,24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MaxWidth="380" BoxShadow="0 6 24 0 #88000000">
                <StackPanel Spacing="16">
                    <TextBlock Text="Start Over?" FontSize="20" FontWeight="Bold"
                               HorizontalAlignment="Center" Foreground="#1A1A1A"/>
                    <TextBlock Text="This will clear all saved decks and your card bank, then reseed the game with brand new cards. This cannot be undone."
                               FontSize="13" Foreground="#555" TextWrapping="Wrap"
                               HorizontalAlignment="Center" TextAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center" Margin="0,8,0,0">
                        <Button Content="Cancel" Classes="btn-gray" Click="CancelStartOver_Click"/>
                        <Button Content="Yes, Start Over" Classes="btn-red" Click="ConfirmStartOver_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>
