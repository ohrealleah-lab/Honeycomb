<local:CardGameView xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SoliBee.Desktop.Views"
             x:Class="SoliBee.Desktop.Views.GameView"
             ClipToBounds="False">

    <Grid x:Name="BoardFeltGrid" ClipToBounds="False">
        <!-- Center container for the entire playing board, aligned towards the top to reduce space with the menu -->
        <StackPanel x:Name="BoardPanel" Width="1004" HorizontalAlignment="Center" VerticalAlignment="Top" Spacing="18" Margin="0,30,0,0" ClipToBounds="False">
            <!-- Top row: Stock, Waste, and Foundations, aligned to Grid columns -->
            <Grid x:Name="TopRowGrid" ColumnDefinitions="128,18,128,18,128,18,128,18,128,18,128,18,128" Width="1004" HorizontalAlignment="Center" ClipToBounds="False">
                <!-- Stock -->
                <local:PileView x:Name="StockPileControl" Grid.Column="0" Clicked="StockPileControl_Clicked" />

                <!-- Waste -->
                <local:PileView x:Name="WastePileControl" Grid.Column="2" />

                <!-- Foundations (aligned to Tableau Columns 4, 5, 6, 7) -->
                <local:PileView x:Name="Foundation0" Grid.Column="6" />
                <local:PileView x:Name="Foundation1" Grid.Column="8" />
                <local:PileView x:Name="Foundation2" Grid.Column="10" />
                <local:PileView x:Name="Foundation3" Grid.Column="12" />
            </Grid>

            <!-- Bottom row: Tableaus -->
            <Grid x:Name="TableauRowGrid" ColumnDefinitions="128,18,128,18,128,18,128,18,128,18,128,18,128" Width="1004" HorizontalAlignment="Center">
                <local:PileView x:Name="Tableau0" Grid.Column="0" />
                <local:PileView x:Name="Tableau1" Grid.Column="2" />
                <local:PileView x:Name="Tableau2" Grid.Column="4" />
                <local:PileView x:Name="Tableau3" Grid.Column="6" />
                <local:PileView x:Name="Tableau4" Grid.Column="8" />
                <local:PileView x:Name="Tableau5" Grid.Column="10" />
                <local:PileView x:Name="Tableau6" Grid.Column="12" />
            </Grid>
        </StackPanel>

        <!-- Global dragging canvas overlay -->
        <Canvas x:Name="DragCanvas" IsHitTestVisible="False" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

        <!-- Bouncing Card Cascade Overlay when won -->
        <local:WinAnimationView x:Name="VictoryOverlay" IsVisible="False" />

        <!-- Inline stuck banner -->
        <Border x:Name="NoMovesBanner" IsVisible="False" ZIndex="5"
                Background="#1A44CC" CornerRadius="12" Padding="28,22"
                BorderBrush="#FFD700" BorderThickness="2" BoxShadow="0 8 30 0 #80000000"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid>
                <StackPanel Spacing="14" HorizontalAlignment="Center">
                    <StackPanel Spacing="2" HorizontalAlignment="Center">
                        <TextBlock Text="No Moves Remaining." FontSize="18" FontWeight="Black"
                                   Foreground="White" HorizontalAlignment="Center" FontFamily="Segoe UI"/>
                        <TextBlock x:Name="NoMovesStatsLabel"
                                   FontSize="14" Foreground="#AAFFFFFF" HorizontalAlignment="Center"
                                   FontFamily="Segoe UI"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                        <Button Content="Restart Game" Click="NoMovesRestart_Click"
                                Padding="18,8" FontSize="13" FontWeight="Bold"
                                Background="#FFD700" Foreground="#1A1A1A"
                                BorderThickness="0" CornerRadius="4"
                                FontFamily="Segoe UI"/>
                        <Button Content="New Game" Click="NoMovesNewGame_Click"
                                Padding="18,8" FontSize="13" FontWeight="Bold"
                                Background="#FFD700" Foreground="#1A1A1A"
                                BorderThickness="0" CornerRadius="4"
                                FontFamily="Segoe UI"/>
                    </StackPanel>
                </StackPanel>
                <Button Classes="banner-close" Content="&#x2715;" Click="NoMovesDismiss_Click" Margin="0,-14,-20,0"/>
            </Grid>
        </Border>

        <!-- Inline autocomplete banner -->
        <Border x:Name="AutocompleteBanner" IsVisible="False" ZIndex="5"
                Background="#1A44CC" CornerRadius="12" Padding="28,22"
                BorderBrush="#FFD700" BorderThickness="2" BoxShadow="0 8 30 0 #80000000"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid>
                <StackPanel Spacing="14" HorizontalAlignment="Center">
                    <StackPanel Spacing="2" HorizontalAlignment="Center">
                        <TextBlock Text="Victory Is Guaranteed!" FontSize="18" FontWeight="Black"
                                   Foreground="White" HorizontalAlignment="Center" FontFamily="Segoe UI"/>
                        <TextBlock Text="All remaining cards can be sorted into foundations."
                                   FontSize="14" Foreground="#AAFFFFFF" HorizontalAlignment="Center"
                                   FontFamily="Segoe UI"/>
                    </StackPanel>
                    <Button Content="Autocomplete Game" Click="AutocompleteGame_Click"
                            Padding="18,8" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"
                            Background="#FFD700" Foreground="#1A1A1A"
                            BorderThickness="0" CornerRadius="4"
                            FontFamily="Segoe UI"/>
                </StackPanel>
                <Button Classes="banner-close" Content="&#x2715;" Click="AutocompleteDismiss_Click" Margin="0,-20,-26,0"/>
            </Grid>
        </Border>

    </Grid>
</local:CardGameView>
