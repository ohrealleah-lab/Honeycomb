<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SoliBee.Desktop.Views.HelpWindow"
        Width="520" Height="580"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Grid RowDefinitions="*, Auto">

        <ScrollViewer Grid.Row="0" Padding="24,20,24,8"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ContentPanel" Spacing="4" />
        </ScrollViewer>

        <Border Grid.Row="1"
                BorderBrush="#3A3A3A" BorderThickness="0,1,0,0"
                Padding="20,12">
            <Button x:Name="CloseButton" Content="Close"
                    Click="Close_Click"
                    HorizontalAlignment="Right" Width="90"
                    HorizontalContentAlignment="Center"
                    Background="#444444" Foreground="White" />
        </Border>

    </Grid>
</Window>
