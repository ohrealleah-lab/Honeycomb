<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:v="clr-namespace:SoliBee.Desktop.Views"
             x:Class="SoliBee.Desktop.Views.PreferencesView">

    <Grid>

        <!-- ═══════════════════════════════════════════════════════════════════
             MAIN OPTIONS PANEL
             ═══════════════════════════════════════════════════════════════════ -->
        <StackPanel x:Name="MainPanel" Spacing="12" Width="270" Margin="10,10,20,10">

            <StackPanel.Styles>
                <Style Selector="CheckBox">
                    <Setter Property="Padding" Value="6,0,0,0" />
                    <Setter Property="MinHeight" Value="24" />
                </Style>
            </StackPanel.Styles>

            <!-- Game Mode (hidden for Video Poker / Blackjack) -->
            <StackPanel x:Name="GameModeSection" IsVisible="False" Spacing="6">
                <TextBlock Text="Game Mode" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                <ComboBox x:Name="GameModeCombo" HorizontalAlignment="Stretch"
                          SelectionChanged="GameMode_Changed"/>
                <Rectangle Height="1" Fill="#30FFFFFF" Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Spacing="2">
                <CheckBox x:Name="TimedCheckBox"        Content="Timed Game"        Checked="Option_Changed" Unchecked="Option_Changed" Foreground="White"/>
                <CheckBox x:Name="SoundCheckBox"        Content="Sound Effects"      Checked="Option_Changed" Unchecked="Option_Changed" Foreground="White"/>
                <CheckBox x:Name="VegasCheckBox"        Content="Vegas Scoring"      Checked="Option_Changed" Unchecked="Option_Changed" Foreground="White"/>
                <CheckBox x:Name="FinalFantasyCheckBox" Content="Final Fantasy Mode" Checked="Option_Changed" Unchecked="Option_Changed" Foreground="White" IsVisible="False"/>
                <CheckBox x:Name="HideHintCheckBox"  Content="Hide Hint button"  Checked="Option_Changed" Unchecked="Option_Changed" Foreground="White"/>
                <CheckBox x:Name="HideStatsCheckBox" Content="Hide Stats button" Checked="Option_Changed" Unchecked="Option_Changed" Foreground="White"/>
                <CheckBox x:Name="HideZoomCheckBox"  Content="Hide Zoom Controls" Checked="Option_Changed" Unchecked="Option_Changed" Foreground="White"/>
                <CheckBox x:Name="HideBetBoardCheckBox" Content="Hide Bet Board" Checked="Option_Changed" Unchecked="Option_Changed" Foreground="White" IsVisible="False"/>
            </StackPanel>

            <Rectangle x:Name="VisualThemesDivider" Height="1" Fill="#30FFFFFF" Margin="0,4,0,4"/>

            <!-- Themes navigation row (not applicable to Video Poker) -->
            <Button x:Name="VisualThemesButton" Click="OpenThemes_Click"
                    Background="#2A2A2A" Foreground="White"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                    Padding="12,10" CornerRadius="6"
                    BorderThickness="1" BorderBrush="#44FFFFFF">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="3">
                        <TextBlock Text="Visual Themes" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="Felt, card back, face card art, colors" FontSize="11" Foreground="#A0A0A0"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="›" FontSize="20" Foreground="#60FFFFFF" VerticalAlignment="Center" Margin="0,0,4,0"/>
                </Grid>
            </Button>

            <Rectangle Height="1" Fill="#30FFFFFF" Margin="0,4,0,4"/>

            <!-- Help & About -->
            <Button Content="Help Guide" Click="Help_Click"
                    Background="#444444" Foreground="White"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />

            <Button Content="About SoliBee" Click="About_Click"
                    Background="#444444" Foreground="White"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Margin="0,4,0,0" />
        </StackPanel>

        <!-- ═══════════════════════════════════════════════════════════════════
             THEMES SUB-PANEL
             ═══════════════════════════════════════════════════════════════════ -->
        <Grid x:Name="ThemesPanel" IsVisible="False" Width="540" Margin="10,10,10,10" RowDefinitions="Auto,*" ColumnDefinitions="*,*">

            <!-- Back button (Row 0, Spans both columns) -->
            <Button Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Click="CloseThemes_Click"
                    Background="Transparent" Foreground="#A0A0A0"
                    HorizontalContentAlignment="Left" Padding="0,2"
                    BorderThickness="0" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <TextBlock Text="‹" FontSize="17" VerticalAlignment="Center"/>
                    <TextBlock Text="Back" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Left Column: Settings and Themes -->
            <StackPanel Grid.Row="1" Grid.Column="0" Spacing="11" Margin="0,0,10,0">

                <!-- ─── SAVED THEMES ──────────────────────────────────────────── -->
                <TextBlock Text="SAVED THEMES" FontSize="10" FontWeight="Bold" Foreground="#60FFFFFF"
                           FontFamily="Segoe UI" LetterSpacing="2" Margin="0,4,0,0"/>
                <Rectangle Height="1" Fill="#20FFFFFF"/>

                <Button x:Name="SaveThemeButton" Content="Save Theme…"
                        Click="SaveTheme_Click"
                        Background="#444444" Foreground="White"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Margin="0,2,0,0"/>
                <StackPanel x:Name="ThemeListPanel" Spacing="2"/>
                <TextBlock x:Name="NoThemesLabel" Text="No saved themes yet." FontSize="11" Foreground="#808080"/>

                <!-- ─── CARD DECK ─────────────────────────────────────────────── -->
                <TextBlock Text="CARD DECK" FontSize="10" FontWeight="Bold" Foreground="#60FFFFFF"
                           FontFamily="Segoe UI" LetterSpacing="2" Margin="0,6,0,0"/>
                <Rectangle Height="1" Fill="#20FFFFFF"/>

                <Grid ColumnDefinitions="*, 12, Auto">
                    <!-- Card Back Selector (Col 0) -->
                    <StackPanel Grid.Column="0" Spacing="6" VerticalAlignment="Bottom">
                        <TextBlock Text="Card Back:" FontWeight="Bold" Foreground="White"/>
                        <ComboBox x:Name="CardBackComboBox" HorizontalAlignment="Stretch" SelectionChanged="CardBackComboBox_SelectionChanged">
                            <ComboBoxItem Content="Vulpera" Tag="Vulpera"/>
                            <ComboBoxItem Content="Dingwall" Tag="Dingwall"/>
                            <ComboBoxItem Content="Moogle"   Tag="Moogle"/>
                        </ComboBox>
                        <Grid ColumnDefinitions="*, *">
                            <Button x:Name="AddCustomCardBackButton"    Grid.Column="0" Content="Add…"  Click="AddCustomCardBack_Click"    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#444444" Foreground="White" Margin="0,0,2,0"/>
                            <Button x:Name="DeleteCustomCardBackButton" Grid.Column="1" Content="Delete" Click="DeleteCustomCardBack_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#662222" Foreground="White" Margin="2,0,0,0" IsEnabled="False"/>
                        </Grid>
                    </StackPanel>

                    <!-- Card Back Preview (Col 2) -->
                    <StackPanel Grid.Column="2" Spacing="3" VerticalAlignment="Bottom">
                        <Border x:Name="CardBackPreviewBorder"
                                Width="80" Height="113"
                                BorderBrush="#D9000000" BorderThickness="0.75"
                                CornerRadius="7" ClipToBounds="True"
                                HorizontalAlignment="Left"
                                Cursor="Hand" Background="White"
                                PointerPressed="CardBackPreview_Click">
                            <Grid Width="80" Height="113" ClipToBounds="True">
                                <Image x:Name="CardBackPreviewImage" Stretch="Uniform"/>
                            </Grid>
                        </Border>
                        <TextBlock Text="Tap to adjust" FontSize="9" Foreground="#808080" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- ─── APPEARANCE ────────────────────────────────────────────── -->
                <TextBlock Text="APPEARANCE" FontSize="10" FontWeight="Bold" Foreground="#60FFFFFF"
                           FontFamily="Segoe UI" LetterSpacing="2" Margin="0,6,0,0"/>
                <Rectangle Height="1" Fill="#20FFFFFF"/>

                <TextBlock Text="Felt Color:" FontWeight="Bold" Foreground="White" Margin="0,2,0,0"/>
                <ComboBox x:Name="FeltColorComboBox" HorizontalAlignment="Stretch" SelectionChanged="FeltColorComboBox_SelectionChanged">
                    <ComboBoxItem Content="Green Felt" Tag="FeltGreen"/>
                    <ComboBoxItem Content="Crimson"    Tag="Crimson"/>
                    <ComboBoxItem Content="Royal Blue" Tag="RoyalBlue"/>
                    <ComboBoxItem Content="Charcoal"   Tag="Charcoal"/>
                    <ComboBoxItem Content="Desert"     Tag="Desert"/>
                    <ComboBoxItem Content="Custom"     Tag="Custom"/>
                </ComboBox>

                <StackPanel x:Name="CustomColorPanel" Spacing="4" IsVisible="False">
                    <TextBlock Text="Choose Custom Color:" FontSize="12" FontWeight="SemiBold" Foreground="LightGray"/>
                    <ColorPicker x:Name="FeltColorPicker" ColorChanged="FeltColorPicker_ColorChanged" HorizontalAlignment="Left"/>
                </StackPanel>

                <CheckBox x:Name="VignetteCheckBox" Content="Felt Vignette"
                          Checked="Option_Changed" Unchecked="Option_Changed" Foreground="White"/>



            </StackPanel>

            <!-- Right Column: Custom Face Card Art & Colors -->
            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="11" Margin="10,0,0,0">

                <!-- ─── CUSTOM CARD ART ───────────────────────────────────────── -->
                <TextBlock Text="CUSTOM CARD ART" FontSize="10" FontWeight="Bold" Foreground="#60FFFFFF"
                           FontFamily="Segoe UI" LetterSpacing="2" Margin="0,4,0,0"/>
                <Rectangle Height="1" Fill="#20FFFFFF"/>

                <TextBlock Text="Tap a tile to upload art. Tap again to adjust." FontSize="10" Foreground="#A0A0A0" Margin="0,2,0,0"/>
                <v:FaceCardArtSectionView/>

                <!-- ─── CUSTOM CARD COLOR ─────────────────────────────────────── -->
                <TextBlock Text="CUSTOM CARD COLOR" FontSize="10" FontWeight="Bold" Foreground="#60FFFFFF"
                           FontFamily="Segoe UI" LetterSpacing="2" Margin="0,12,0,0"/>
                <Rectangle Height="1" Fill="#20FFFFFF"/>

                <!-- Grid of Color Pickers -->
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto" Margin="0,4,0,4">
                    <!-- Card Background -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Card Background:" VerticalAlignment="Center" Foreground="White"/>
                    <ColorPicker Grid.Row="0" Grid.Column="1" x:Name="CardBgColorPicker" ColorChanged="CardColorPicker_ColorChanged" HorizontalAlignment="Right" Margin="0,2,0,2"/>

                    <!-- Card Outline -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Card Outline:" VerticalAlignment="Center" Foreground="White"/>
                    <ColorPicker Grid.Row="1" Grid.Column="1" x:Name="CardOutlineColorPicker" ColorChanged="CardColorPicker_ColorChanged" HorizontalAlignment="Right" Margin="0,2,0,2"/>

                    <!-- Card Text - Black Suits -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Text (Black Suits):" VerticalAlignment="Center" Foreground="White"/>
                    <ColorPicker Grid.Row="2" Grid.Column="1" x:Name="CardTextBlackColorPicker" ColorChanged="CardColorPicker_ColorChanged" HorizontalAlignment="Right" Margin="0,2,0,2"/>

                    <!-- Card Text - Red Suits -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Text (Red Suits):" VerticalAlignment="Center" Foreground="White"/>
                    <ColorPicker Grid.Row="3" Grid.Column="1" x:Name="CardTextRedColorPicker" ColorChanged="CardColorPicker_ColorChanged" HorizontalAlignment="Right" Margin="0,2,0,2"/>
                </Grid>

                <Button Content="Reset Card Colors" Click="ResetCardColors_Click" Background="#442222" Foreground="White" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,2,0,0"/>

            </StackPanel>

        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════════
             OVERLAYS  (cover whichever panel is active)
             ═══════════════════════════════════════════════════════════════════ -->

        <!-- Delete Card Back Confirmation -->
        <Grid x:Name="ConfirmDeleteOverlay" Background="#D0000000" IsVisible="False" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Background="#2E2E2E" CornerRadius="8" Padding="15" VerticalAlignment="Center" HorizontalAlignment="Center" BoxShadow="0 4 15 0 #A0000000">
                <StackPanel Spacing="12" Width="230">
                    <TextBlock Text="Delete Card Back" FontSize="15" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="Are you sure you want to delete this custom card back? This cannot be undone." FontSize="12" Foreground="LightGray" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>
                    <Grid ColumnDefinitions="*, *" Margin="0,5,0,0">
                        <Button Content="Cancel" Click="CancelDelete_Click"  Grid.Column="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#444444" Foreground="White" Margin="0,0,4,0"/>
                        <Button Content="Delete" Click="ConfirmDelete_Click" Grid.Column="1" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#882222" Foreground="White" Margin="4,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Save Theme Name -->
        <Grid x:Name="SaveThemeOverlay" Background="#D0000000" IsVisible="False" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Background="#2E2E2E" CornerRadius="8" Padding="15" VerticalAlignment="Center" HorizontalAlignment="Center" BoxShadow="0 4 15 0 #A0000000">
                <StackPanel Spacing="12" Width="230">
                    <TextBlock Text="Save Theme" FontSize="15" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="Enter a name for this theme:" FontSize="12" Foreground="LightGray"/>
                    <TextBox x:Name="ThemeNameInput" Watermark="Theme name…" BorderBrush="#666666" Foreground="Black"/>
                    <Grid ColumnDefinitions="*, *" Margin="0,5,0,0">
                        <Button Content="Cancel" Click="CancelSaveTheme_Click"  Grid.Column="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#444444" Foreground="White" Margin="0,0,4,0"/>
                        <Button Content="Save"   Click="ConfirmSaveTheme_Click" Grid.Column="1" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#225522" Foreground="White" Margin="4,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Confirm Delete Theme -->
        <Grid x:Name="ConfirmDeleteThemeOverlay" Background="#D0000000" IsVisible="False" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Background="#2E2E2E" CornerRadius="8" Padding="15" VerticalAlignment="Center" HorizontalAlignment="Center" BoxShadow="0 4 15 0 #A0000000">
                <StackPanel Spacing="12" Width="230">
                    <TextBlock Text="Delete Theme" FontSize="15" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="DeleteThemeConfirmText" Text="Delete this theme?" FontSize="12" Foreground="LightGray" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>
                    <Grid ColumnDefinitions="*, *" Margin="0,5,0,0">
                        <Button Content="Cancel" Click="CancelDeleteTheme_Click"  Grid.Column="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#444444" Foreground="White" Margin="0,0,4,0"/>
                        <Button Content="Delete" Click="ConfirmDeleteTheme_Click" Grid.Column="1" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#882222" Foreground="White" Margin="4,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>
